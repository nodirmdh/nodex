{
  "name": "nodex",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm -w apps/api run dev",
    "dev:worker": "npm --prefix worker run dev",
    "dev:admin": "npm -w apps/admin-web run dev",
    "dev:client": "npm -w apps/client-miniapp run dev",
    "dev:courier": "npm -w apps/courier-miniapp run dev",
    "dev:vendor": "npm -w apps/vendor-miniapp run dev",
    "dev:vendor-web": "npm -w apps/vendor-web run dev",
    "dev:vendor-miniapp": "npm -w apps/vendor-miniapp run dev",
    "deploy:worker": "npm --prefix worker run deploy",
    "test:worker": "npm --prefix worker run test",
    "typecheck:all": "npm --prefix worker run typecheck && npm -w apps/client-miniapp run typecheck && npm -w apps/vendor-miniapp run typecheck && npm -w apps/admin-web run typecheck",
    "build:client": "npm -w apps/client-miniapp run build",
    "build:vendor": "npm -w apps/vendor-miniapp run build",
    "build:admin": "npm -w apps/admin-web run build",
    "build:all": "npm run build:client && npm run build:vendor && npm run build:admin",
    "seed:d1": "node tools/seed-d1.mjs",
    "test": "npm -ws run test --if-present",
    "seed": "npm -w apps/api run seed",
    "test:unit": "npm -w apps/api run test:unit",
    "test:int": "npm -w apps/api run test:int",
    "lint": "npm -ws run lint",
    "typecheck": "npm -ws run typecheck",
    "build": "npm -ws run build"
  }
}
